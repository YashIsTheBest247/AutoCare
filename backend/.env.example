DATABASE_URL=sqlite:///./autocare.db
MODEL_PATH=../ml/models/failure_model.joblib
MODEL_META_PATH=../ml/models/model_meta.json
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720
DEFAULT_ADMIN_EMAIL=admin@autocare.ai
DEFAULT_ADMIN_PASSWORD=admin123

# Email alerts (optional). Both SMTP_* and MAIL_* names are accepted.
# Gmail example (works locally; Render blocks port 587 — use a provider with 2525 there):
#   MAIL_SERVER=smtp.gmail.com  MAIL_PORT=587  MAIL_PASSWORD=<gmail app password>
# Brevo example (recommended for Render/cloud, port 2525):
#   MAIL_SERVER=smtp-relay.brevo.com  MAIL_PORT=2525  MAIL_USERNAME=<login>@smtp-brevo.com  MAIL_PASSWORD=<xsmtpsib- key>
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=alerts@autocare.ai
MAIL_STARTTLS=True
